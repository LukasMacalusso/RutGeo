<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RutGeo.UI.Views.Mode">
    <StackPanel Orientation="Horizontal">
        <Button x:Name="BtnLimits" Content="Límites" Click="LimitsButton_Click" 
                Background="#1A1837" Foreground="LightGray" BorderThickness="0"/>
        <Button x:Name="BtnConics" Content="Cónicas" Click="ConicsButton_Click" 
                Background="MediumSlateBlue" Foreground="White" BorderThickness="0" CornerRadius="3" Margin="0,0,5,0"/>
    </StackPanel>
</UserControl>
