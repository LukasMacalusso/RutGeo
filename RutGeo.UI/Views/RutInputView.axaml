<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RutGeo.UI.Views.RutInputView">

    <Border Background="#F5F5FB" BorderBrush="#D4D4E2" BorderThickness="0,1,0,0" Padding="15">
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="5">
            <TextBlock Text="RUT" Foreground="#333333" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox Width="200" PlaceholderText="12345678-9" VerticalAlignment="Center"/>
            <Button x:Name="BtnConics" Content="Calcular"
                    Background="MediumSlateBlue" Foreground="White" BorderThickness="0" CornerRadius="3" Margin="0,0,5,0"/>
        </StackPanel>
    </Border>

</UserControl>