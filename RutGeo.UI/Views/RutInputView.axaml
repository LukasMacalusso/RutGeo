<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RutGeo.UI.Views.RutInputView">

    <Border Background="#F5F5FB" BorderBrush="#D4D4E2" BorderThickness="0,1,0,0" Padding="15">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
            <TextBlock Text="RUT" Foreground="#333333" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox Width="200" Watermark="12345678-9" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>

</UserControl>